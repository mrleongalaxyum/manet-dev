* text=auto

# Runtime files shipped into the Linux rootfs must stay LF on Windows checkouts.
*.sh text eol=lf
*.py text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.socket text eol=lf
*.target text eol=lf
*.conf text eol=lf
*.rules text eol=lf
*.env text eol=lf
*.proto text eol=lf
rpi5/rpi5-install/etc/sudoers.d/* text eol=lf
rpi5/rpi5-install/usr/local/bin/* text eol=lf

# Binary payloads and archives.
*.bin binary
*.ko binary
*.ko.xz binary
*.dtb binary
*.img binary
*.gz binary
*.xz binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.svg text eol=lf
