#!/bin/bash
TARGET_IFACE="end0"
GATEWAY_STATE_FILE="/var/run/mesh-gateway.state"
NTP_STATE_FILE="/var/run/mesh-ntp.state"
ETHERNET_STATE_FILE="/var/run/ethernet_detection_state"

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] - ETH-OFF: $1" | systemd-cat -t ethernet-off
}

if [ "$IFACE" != "$TARGET_IFACE" ]; then
    exit 0
fi


DEBOUNCE_FILE="/var/run/eth-off-debounce"
if [ -f "$DEBOUNCE_FILE" ]; then
    age=$(( $(date +%s) - $(stat -c %Y "$DEBOUNCE_FILE") ))
    if [ "$age" -lt 4 ]; then
        log "Debounce: skipping duplicate cleanup (${age}s since last run)"
        exit 0
    fi
fi
touch "$DEBOUNCE_FILE"


log "Cable unplugged from $IFACE - cleaning up all ethernet configurations..."

# Stop all ethernet-related services
systemctl stop dnsmasq.service 2>/dev/null

# Flush all IPs from end0
log "Flushing IP addresses from $IFACE"
ip addr flush dev "$IFACE" 2>/dev/null
ip link set "$IFACE" nomaster 2>/dev/null || true

# Remove all networkd configs for end0
log "Removing networkd configs"
rm -f /etc/systemd/network/20-end0.network
rm -f /etc/systemd/network/20-end0-*.network

# Restore default DHCP config
log "Restoring default DHCP config"
cp /etc/systemd/network/10-end0.network.dhcp-default /etc/systemd/network/10-end0.network 2>/dev/null || true

# Restart networkd to apply changes
networkctl reload 2>/dev/null || true
networkctl reconfigure end0 2>/dev/null || true

# Remove dnsmasq wired-eud config
rm -f /etc/dnsmasq.d/mesh-wired-eud.conf 2>/dev/null

# If we were a gateway, revert that too
if [ -f "$GATEWAY_STATE_FILE" ]; then
    log "Was gateway - reverting gateway-specific settings..."

    # Stop NTP server
    if systemctl is-active --quiet chrony.service; then
        systemctl stop chrony.service
        cp /etc/chrony/chrony-default.conf /etc/chrony/chrony.conf
    fi

    # Revert batman-adv mode
    batctl gw_mode client 2>/dev/null

    # Revert radvd
    cp /etc/radvd-mesh.conf /etc/radvd.conf
    systemctl restart radvd 2>/dev/null

    # Remove NAT
    nft flush chain ip nat postrouting 2>/dev/null || true
fi

# Remove all state files
rm -f "$GATEWAY_STATE_FILE"
rm -f "$NTP_STATE_FILE"
rm -f "$ETHERNET_STATE_FILE"

AP_INTERFACE=""
if [ -f /var/lib/ap_interface ]; then
    AP_INTERFACE=$(cat /var/lib/ap_interface)
fi

# With no ethernet, keep wireless EUD service alive. AUTO also falls back to AP.
EUD_MODE=$(grep "^eud=" /etc/mesh.conf 2>/dev/null | cut -d'=' -f2)
if { [ "$EUD_MODE" == "auto" ] || [ "$EUD_MODE" == "wireless" ]; } && [ -f /var/lib/ap_interface ]; then
    log "$EUD_MODE mode: No ethernet, ensuring AP/DHCP stays enabled"
    systemctl unmask dnsmasq.service 2>/dev/null
    systemctl enable hostapd.service 2>/dev/null
    systemctl start hostapd.service 2>/dev/null
    systemctl enable dnsmasq.service 2>/dev/null
    systemctl start dnsmasq.service 2>/dev/null
    systemctl start ap-txpower.service 2>/dev/null

    # Bridge AP interface to br0 for EUD connectivity
    if [ -n "$AP_INTERFACE" ]; then
        if ! ip link show "$AP_INTERFACE" | grep -q "master br0"; then
            log "Bridging $AP_INTERFACE to br0"
            ip link set "$AP_INTERFACE" master br0
            ip link set "$AP_INTERFACE" up
        fi
    fi
fi

batctl gw_mode client 2>/dev/null || true
nft flush chain ip nat postrouting 2>/dev/null || true
/usr/local/bin/mesh-ip-manager.sh 2>/dev/null || true
systemctl restart gateway-route-manager.service 2>/dev/null || true

log "Cleanup complete"
